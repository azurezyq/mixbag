rules_version = '2';

// Fairy Database Rules v1.1 (Troubleshooting)
service cloud.firestore {
  match /databases/{database}/documents {
    // Base templates: Anyone can read
    match /checklists/{checklist} {
      allow read: if true;
      allow write: if false;
    }
    
    // User lists: Only the owner can read/write
    match /user_checklists/{list} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // AI Chats: Only the owner
    match /ai_chats/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
